{
  "actorOutputSchemaVersion": 1,
  "fields": [
    { "name": "company",         "type": "string",  "description": "Company name as supplied in input" },
    { "name": "platform",        "type": "string",  "description": "Review platform: g2 | capterra | trustpilot" },
    { "name": "reviewer_name",   "type": "string",  "description": "Reviewer's display name" },
    { "name": "reviewer_title",  "type": "string",  "description": "Reviewer's job title" },
    { "name": "reviewer_company_size", "type": "string", "description": "Reviewer's company size band" },
    { "name": "rating",          "type": "number",  "description": "Star rating out of 5" },
    { "name": "title",           "type": "string",  "description": "Review headline" },
    { "name": "body",            "type": "string",  "description": "Full review text" },
    { "name": "pros",            "type": "string",  "description": "Pros section (G2/Capterra)" },
    { "name": "cons",            "type": "string",  "description": "Cons section (G2/Capterra)" },
    { "name": "date",            "type": "string",  "description": "Review date (ISO 8601)" },
    { "name": "verified",        "type": "boolean", "description": "Whether the review is verified" },
    { "name": "helpful_count",   "type": "integer", "description": "Number of helpful votes" },
    { "name": "review_url",      "type": "string",  "description": "Direct URL to the review" },
    { "name": "product_url",     "type": "string",  "description": "URL of the product/company page scraped" }
  ],
  "views": {
    "overview": {
      "title": "Reviews",
      "transformation": { "fields": ["company", "platform", "rating", "reviewer_name", "reviewer_title", "title", "date", "verified"] },
      "display": {
        "component": "table",
        "properties": {
          "company":        { "label": "Company",   "format": "text" },
          "platform":       { "label": "Platform",  "format": "text" },
          "rating":         { "label": "Rating",    "format": "number" },
          "reviewer_name":  { "label": "Reviewer",  "format": "text" },
          "reviewer_title": { "label": "Title",     "format": "text" },
          "title":          { "label": "Review",    "format": "text" },
          "date":           { "label": "Date",      "format": "date" },
          "verified":       { "label": "Verified",  "format": "boolean" }
        }
      }
    }
  }
}
